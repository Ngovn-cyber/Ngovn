                        local zombieHrp = zombie:FindFirstChild("HumanoidRootPart")
                        if zombieHrp and (hrp.Position - zombieHrp.Position).Magnitude <= KillAuraRange then
                            local tool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool") or Character:FindFirstChildOfClass("Tool")
                            if tool then
                                if not Character:FindFirstChild(tool.Name) then LocalPlayer.Humanoid:EquipTool(tool) end
                                tool:Activate()
                                if ReplicatedStorage:FindFirstChild("DamageRemote") then ReplicatedStorage.DamageRemote:FireServer(zombie.Humanoid, 9999) end
                            end
                        end
                    end
                end
            end
        end)
    end
end)

